# LLM Provider API Keys (LiteLLM supports all major providers)
# Set the key for whichever provider you're using

# OpenAI (default provider)
OPENAI_API_KEY=sk-...

# Anthropic (optional - for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google (optional - for Gemini models)
# GEMINI_API_KEY=...

# Azure OpenAI (optional)
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/

# Default model (any LiteLLM-supported model identifier)
DEFAULT_MODEL=gpt-4o

# ── LLM Provider Mode ──────────────────────────────────────────────
# "direct"        — Use API keys above with LiteLLM (default)
# "copilot_proxy" — Route through a local Copilot proxy (e.g. vscode-lm-proxy)
LLM_PROVIDER=direct

# Copilot Proxy settings (only used when LLM_PROVIDER=copilot_proxy)
# Install "LM Proxy" from VS Code Marketplace: https://marketplace.visualstudio.com/items?itemName=ryonakae.vscode-lm-proxy
# COPILOT_PROXY_URL=http://localhost:4000/v1
# COPILOT_PROXY_MODEL=copilot-gpt-4o

# Application Settings
BACKEND_PORT=8000
FRONTEND_PORT=3000
