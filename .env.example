# LLM Provider API Keys (LiteLLM supports all major providers)
# Set the key for whichever provider you're using

# OpenAI (default provider)
OPENAI_API_KEY=sk-...

# Anthropic (optional - for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google (optional - for Gemini models)
# GEMINI_API_KEY=...

# Azure OpenAI (optional)
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com/

# Default model (any LiteLLM-supported model identifier)
DEFAULT_MODEL=gpt-4o

# Application Settings
BACKEND_PORT=8000
FRONTEND_PORT=3000
